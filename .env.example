GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=

SINGLE_USER_MODE=false
ALLOW_HEADER_AUTH=true

MASTER_KEY=replace_with_a_long_random_secret
# Optional legacy compatibility key. Leave empty unless you need it.
MASTER_ENCRYPTION_KEY=
BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_strong_admin_password

# Optional if you use Supabase auth storage instead of local JSON
SUPABASE_DATABASE_URL=

# Optional CORS override for browsers outside the container host
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
